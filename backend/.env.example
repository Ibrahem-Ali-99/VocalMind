PROJECT_NAME="VocalMind API"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Security
# Generate a strong key: `openssl rand -hex 32`
SECRET_KEY=""
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8000/api/v1/auth/google/callback"

# Database (Docker Postgres)
DATABASE_URL="postgresql+asyncpg://vocalmind:vocalmind_dev@localhost:5432/vocalmind"

# AI Service Routing
# true = Docker containers (EMOTION_API_URL + VAD_API_URL)
# false = Kaggle server (KAGGLE_SERVER_URL)
IS_LOCAL=true
EMOTION_API_URL="http://localhost:8001"
VAD_API_URL="http://localhost:8002"
KAGGLE_SERVER_URL="https://xxxx.ngrok-free.app"

# System
FFMPEG_PATH=""
# Kaggle Emotion API (ngrok URL)
KAGGLE_NGROK_URL="https://xxxx.ngrok-free.app"
KAGGLE_API_SECRET="your_shared_secret_key"
HF_TOKEN="your_huggingface_token"

# Text Emotion Fusion
TEXT_EMOTION_PROVIDER="hf_transformers"
TEXT_EMOTION_MODEL="j-hartmann/emotion-english-distilroberta-base"
