# Groq API Key (get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Ollama (default: localhost if running via Docker Compose)
OLLAMA_BASE_URL=http://localhost:11434

# Embedding model (pulled via: ollama pull snowflake-arctic-embed2)
EMBEDDING_MODEL=snowflake-arctic-embed2

# Qdrant (default: localhost if running via Docker Compose)
QDRANT_URL=http://localhost:6333

# Document paths (relative to final-rag/ or absolute)
DOCS_DIR=docs
PARSED_DIR=parsed_docs
